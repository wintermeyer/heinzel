# All user state lives under memory/.
# Solo mode by default; team mode is opt-in below.

# Start by ignoring everything in memory/, then
# explicitly allow the tracked templates and keep
# markers.
memory/*
!memory/MEMORY.md
!memory/user.md.example
!memory/opencode.json.example
!memory/service-policy.md.example

# Server memory directory — keep the folder in git
# but ignore its contents (solo mode). For team
# mode, un-ignore the contents by uncommenting the
# `!memory/servers/**` line below.
!memory/servers/
memory/servers/*
!memory/servers/.gitkeep

# Custom rule overrides — keep the folder in git
# but ignore its contents (solo mode). For team
# mode, un-ignore *.md by uncommenting the
# `!memory/custom-rules/*.md` line below.
!memory/custom-rules/
memory/custom-rules/*
!memory/custom-rules/.gitkeep

# ---- Team mode (opt-in) --------------------------
# Uncomment the lines you want to share via git.
# memory/user.md and memory/opencode.json are
# always personal and must NEVER be shared.
# !memory/blacklist.md
# !memory/readonly.md
# !memory/service-policy.md
# !memory/housekeeping.md
# !memory/network.md
# !memory/servers/**
# memory/servers/localhost/
# memory/servers/127.0.0.1/
# !memory/custom-rules/*.md

# Project history (auto-maintained by Claude Code).
HISTORY.md

# macOS noise.
.DS_Store

# Claude Code harness runtime artifacts (session/task locks).
# Not shipped with heinzel; created by /loop, /schedule, and
# the scheduler machinery in the Claude Code CLI.
.claude/*.lock
